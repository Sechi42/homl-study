# ──────────────────────────────────────────────
#  Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.installed.cfg
lib/
lib64/
wheels/

# ──────────────────────────────────────────────
#  Virtual environments
# ──────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.conda/

# ──────────────────────────────────────────────
#  Jupyter / notebooks
# ──────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/
**/.ipynb_checkpoints/
*.ipynb_checkpoints

# ──────────────────────────────────────────────
#  Datasets  — CSV/TSV in data/ ARE tracked.
#  Only exclude very large binary files.
# ──────────────────────────────────────────────
# Large binary dataset formats — do NOT commit these to git
*.parquet
*.h5
*.hdf5
*.npy
*.npz
*.zip
*.tar.gz
*.tar.bz2
*.gz
*.7z

# Trained model weights (often 100s of MB)
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.onnx

# Pickle / joblib caches
*.pkl
*.pickle

# ──────────────────────────────────────────────
#  IDE / editor
# ──────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────
#  Misc
# ──────────────────────────────────────────────
.env
.envrc
*.log
*.out
*.err
